\START

\AUTHOR{Liam Huang}

\ExplSyntaxOn

\TEST{custom~CJKglue~preserved~in~body}{
  \cs_log:N \CJKglue
}

\TEST{linestretch~does~not~override~custom~CJKglue}{
  \ctexset{linestretch = \ccwd}
  \cs_log:N \CJKglue
}

\TEST{custom~CJKglue~preserved~after~zihao}{
  \group_begin:
    \zihao{-4}
    \cs_log:N \CJKglue
  \group_end:
}

\ExplSyntaxOff

