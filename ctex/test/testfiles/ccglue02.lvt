\documentclass[fontset=fandol]{ctexart}

\ExplSyntaxOn
\sys_if_engine_xetex:T
  { \xeCJKsetup { CJKglue = { \hskip 0.8em plus 0.08em minus 0.02em } } }
\sys_if_engine_pdftex:T
  { \cs_set_protected:Npn \CJKglue { \hskip 0.8em plus 0.08em minus 0.02em } }
