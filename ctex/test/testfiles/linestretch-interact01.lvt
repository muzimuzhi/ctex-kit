}

\TEST{linestretch~maxdimen~disables}{
  \ctexset{linestretch = \maxdimen}
  \dim_log:n { \baselineskip }
}

\TEST{linestretch~with~zihao~change}{
  \ctexset{linestretch = \ccwd}
