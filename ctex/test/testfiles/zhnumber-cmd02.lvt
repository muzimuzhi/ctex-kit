\input{regression-test}

\documentclass[fontset=fandol]{ctexart}

\begin{document}

\START

\AUTHOR{Liam Huang}

\ExplSyntaxOn

\TEST{CTEXnumber~1~to~10}{
  \int_step_inline:nnn { 1 } { 10 }
    {
      \CTEXnumber \l_tmpa_tl {##1}
      \tl_log:N \l_tmpa_tl
    }
}

\TEST{CTEXnumber~large}{
  \CTEXnumber \l_tmpa_tl {100}
  \tl_log:N \l_tmpa_tl
  \CTEXnumber \l_tmpa_tl {1000}
  \tl_log:N \l_tmpa_tl
  \CTEXnumber \l_tmpa_tl {10000}
  \tl_log:N \l_tmpa_tl
}

\TEST{CTEXdigits~basic}{
  \CTEXdigits \l_tmpa_tl {2025}
  \tl_log:N \l_tmpa_tl
  \CTEXdigits \l_tmpa_tl {0}
  \tl_log:N \l_tmpa_tl
}

\ExplSyntaxOff

\END

\end{document}
