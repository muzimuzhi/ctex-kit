\TEST{default~today~format}{
  \tl_log:x { \today }
}

\TEST{today~small~format}{
  \ctexset{today = small}
  \tl_log:x { \today }
}

\TEST{today~big~format}{
  \ctexset{today = big}
  \tl_log:x { \today }
}

\TEST{today~old~format}{
  \ctexset{today = old}
  \tl_log:x { \today }
}

\ExplSyntaxOff

\END

