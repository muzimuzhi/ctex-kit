\input{regression-test}

\documentclass[fontset=fandol]{ctexbook}

\begin{document}

\START

\AUTHOR{Liam Huang}

\ExplSyntaxOn

\TEST{default~chapter~name}{
  \cs_log:c { CTEX@chapter@name@pre }
  \cs_log:c { CTEX@chapter@name@post }
}

\TEST{default~chapter~number}{
  \cs_log:c { CTEX@chapter@number }
}

\TEST{custom~chapter~name}{
  \ctexset{chapter/name = {篇,}}
  \cs_log:c { CTEX@chapter@name@pre }
  \cs_log:c { CTEX@chapter@name@post }
}

\TEST{default~section~name}{
  \cs_log:c { CTEX@section@name@pre }
  \cs_log:c { CTEX@section@name@post }
}

\ExplSyntaxOff

\END

\end{document}
