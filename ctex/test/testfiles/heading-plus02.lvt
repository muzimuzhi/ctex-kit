\input{regression-test}

\documentclass[fontset=fandol]{ctexart}

\begin{document}

\START

\AUTHOR{Liam Huang}

\ExplSyntaxOn

\TEST{multiple~ctexset~accumulate}{
  \ctexset{section/format = \Large\bfseries}
  \cs_log:c { CTEX@section@format }
  \ctexset{section/format += \raggedright}
  \cs_log:c { CTEX@section@format }
  \ctexset{section/format += \itshape}
  \cs_log:c { CTEX@section@format }
}

\TEST{plus~does~not~leak~across~levels}{
  \ctexset{section/format += \color{red}}
  \cs_log:c { CTEX@section@format }
  \cs_log:c { CTEX@subsection@format }
}

\TEST{aftername~plus}{
  \ctexset{section/aftername = \quad}
  \cs_log:c { CTEX@section@aftername }
  \ctexset{section/aftername += \hskip 1em}
  \cs_log:c { CTEX@section@aftername }
}

\ExplSyntaxOff

\END

\end{document}
