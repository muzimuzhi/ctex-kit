\input{regression-test}

\documentclass[fontset=fandol, scheme=chinese]{ctexart}

\begin{document}

\START

\AUTHOR{Liam Huang}

\ExplSyntaxOn

\TEST{indentfirst~loaded}{
  \cs_if_exist:NTF \@afterindentfalse
    { \TYPE { indentfirst:~ active } }
    { \TYPE { indentfirst:~ not~loaded } }
}

\TEST{pagestyle~is~headings}{
  \cs_log:c { ps@headings }
}

\TEST{baselineskip~default~chinese}{
  \dim_log:n { \baselineskip }
}

\TEST{parindent~is~2ccwd}{
  \dim_log:n { \parindent }
  \dim_log:N \ccwd
  \dim_log:n { 2\ccwd }
}

\ExplSyntaxOff

\END

\end{document}
